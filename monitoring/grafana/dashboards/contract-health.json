{
  "title": "Contract Health",
  "uid": "qp-contract-health",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Contract Paused",
      "type": "stat",
      "targets": [
        {
          "expr": "quorumproof_contract_paused",
          "legendFormat": "paused"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "PAUSED", "color": "red" } } }
          ]
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 2,
      "title": "API Up",
      "type": "stat",
      "targets": [
        {
          "expr": "up{job=\"quorumproof-exporter\"}",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 3,
      "title": "Error Rate (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "rate(quorumproof_api_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 4,
      "title": "Active Slices",
      "type": "stat",
      "targets": [
        {
          "expr": "quorumproof_active_slices_total",
          "legendFormat": "slices"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 5,
      "title": "Recent Errors by Code",
      "type": "table",
      "targets": [
        {
          "expr": "sum by (error_code) (increase(quorumproof_api_errors_total[1h]))",
          "legendFormat": "{{error_code}}",
          "instant": true
        }
      ],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(quorumproof_api_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ],
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 7,
      "title": "Contract Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"quorumproof-api\"}",
          "legendFormat": ""
        }
      ],
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 }
    }
  ]
}
